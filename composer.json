{
    "name": "pn-suite/pn-ai-agent",
    "description": "Open-source AI Assistant plugin for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",

    "keywords": [
        "wordpress",
        "ai",
        "chatbot",
        "openai",
        "gemini",
        "ollama"
    ],

    "homepage": "https://plugins.puyanovin.ir/pn-ai-agent",

    "authors": [
        {
            "name": "PN Suite",
            "homepage": "https://plugins.puyanovin.ir"
        }
    ],

    "autoload": {
        "psr-4": {
            "PNAIAgent\\": "src/"
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true,

    "require": {},

    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2"
    },

    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    }
}
